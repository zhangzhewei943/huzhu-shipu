.tab-bar{display:flex;align-items:flex-start;justify-content:space-around;padding:16rpx 32rpx 0;padding-bottom:env(safe-area-inset-bottom);background:rgba(255,255,255,0.8);backdrop-filter:blur(40px);border-top:1rpx solid var(--border);}
.tab{display:flex;flex-direction:column;align-items:center;gap:6rpx;width:120rpx;padding:8rpx 0;}
.icon{width:48rpx;height:48rpx;}
.label{font-size:20rpx;font-weight:500;color:#8c8c8c;}
.tab.active .label{color:#D98531;}
