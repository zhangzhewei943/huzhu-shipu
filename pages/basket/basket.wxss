.page{display:flex;flex-direction:column;height:100vh;background:var(--cream);}
.hero{padding:32rpx 32rpx 24rpx;}
.kicker{font-size:22rpx;color:var(--accent);letter-spacing:4rpx;}
.title{font-size:40rpx;font-weight:700;display:block;margin:8rpx 0;}
.sub{font-size:26rpx;color:var(--muted);}
.ring{margin-top:20rpx;display:flex;align-items:baseline;gap:8rpx;}
.ring-num{font-size:56rpx;font-weight:700;color:var(--accent);}
.ring-label{font-size:28rpx;color:var(--muted);}
.list{flex:1;padding:0 24rpx;}
.recipe-group{margin-bottom:24rpx;}
.recipe-name{font-size:30rpx;font-weight:600;display:block;margin-bottom:8rpx;}
.ing-row{display:flex;align-items:center;gap:16rpx;padding:16rpx 20rpx;background:var(--surface);border-radius:12rpx;margin-bottom:8rpx;}
.ing-row.checked{opacity:0.4;}
.ing-check{font-size:28rpx;color:var(--accent);width:40rpx;}
.ing-text{font-size:28rpx;}
.empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80rpx;}
.empty-icon{font-size:80rpx;margin-bottom:24rpx;opacity:0.5;}
.empty-text{font-size:32rpx;color:var(--muted);margin-bottom:8rpx;}
.empty-hint{font-size:26rpx;color:var(--muted);opacity:0.6;}
