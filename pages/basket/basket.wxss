.page{display:flex;flex-direction:column;min-height:100vh;background:var(--cream);}
.hero{padding:32rpx 32rpx 24rpx;}
.kicker{font-size:22rpx;color:var(--accent);letter-spacing:4rpx;}
.title{font-size:40rpx;font-weight:700;display:block;margin:8rpx 0;}
.sub{font-size:26rpx;color:var(--muted);display:block;}
.ring-wrap{margin-top:24rpx;}
.ring{display:flex;align-items:baseline;gap:4rpx;margin-bottom:4rpx;}
.ring-num{font-size:64rpx;font-weight:700;color:var(--accent);}
.ring-total{font-size:28rpx;color:var(--muted);}
.ring-sub{font-size:24rpx;color:var(--muted);}

.list{flex:1;padding:0 24rpx;}
.ing-row{display:flex;align-items:center;gap:20rpx;padding:20rpx 24rpx;background:var(--surface);border-radius:14rpx;margin-bottom:10rpx;}
.ing-row.checked{opacity:0.35;}
.ing-row.checked .ing-text{text-decoration:line-through;}
.ing-check{font-size:32rpx;color:var(--accent);width:44rpx;text-align:center;}
.ing-info{flex:1;}
.ing-text{font-size:28rpx;display:block;}
.ing-source{font-size:22rpx;color:var(--muted);display:block;margin-top:4rpx;}

.empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80rpx;}
.empty-icon{font-size:80rpx;margin-bottom:24rpx;opacity:0.5;}
.empty-text{font-size:32rpx;color:var(--muted);margin-bottom:8rpx;}
.empty-hint{font-size:26rpx;color:var(--muted);opacity:0.6;margin-bottom:32rpx;text-align:center;}
.empty-btn{padding:16rpx 56rpx;background:var(--accent);color:#fff;font-size:28rpx;border-radius:32rpx;border:none;}

.bottom-bar{display:flex;align-items:center;justify-content:space-between;padding:24rpx 32rpx;padding-bottom:calc(24rpx+env(safe-area-inset-bottom));border-top:1rpx solid var(--border);background:var(--surface);}
.btn-clear{background:none;color:#E05050;font-size:28rpx;border:none;padding:0;}
.bar-status{color:var(--accent);font-weight:600;font-size:28rpx;}
