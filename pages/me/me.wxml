<view class="page">
  <view class="profile">
    <view class="avatar">🍳</view>
    <view class="profile-name">美食爱好者</view>
  </view>

  <view class="stats">
    <view class="stat"><text class="n">{{selectedCount}}</text><text class="l">我的菜篮</text></view>
    <view class="stat"><text class="n">{{recipeCount}}</text><text class="l">菜谱总数</text></view>
    <view class="stat"><text class="n">{{basketItems}}</text><text class="l">食材项</text></view>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="clearBasket"><text>清空菜篮</text><text class="arrow">›</text></view>
    <view class="menu-item" bindtap="clearSelection"><text>清空选择</text><text class="arrow">›</text></view>
    <view class="menu-item"><text>关于我们</text><text class="arrow">›</text></view>
    <view class="menu-item"><text>设置</text><text class="arrow">›</text></view>
  </view>
</view>
