.page{min-height:100vh;background:var(--cream);}
.hero{display:flex;flex-direction:column;align-items:center;padding:48rpx 32rpx;}
.hero-icon{width:120rpx;height:120rpx;border-radius:24rpx;display:flex;align-items:center;justify-content:center;font-size:60rpx;margin-bottom:20rpx;}
.hero-name{font-size:40rpx;font-weight:700;margin-bottom:8rpx;}
.hero-time{font-size:26rpx;color:var(--muted);}
.section{margin:16rpx 24rpx;padding:28rpx;background:var(--surface);border-radius:16rpx;}
.sec-label{font-size:30rpx;font-weight:600;margin-bottom:16rpx;}
.ing-item{font-size:28rpx;padding:12rpx 0;border-bottom:1rpx solid var(--border);}
.ing-item:last-child{border-bottom:none;}
.step-item{display:flex;gap:16rpx;padding:16rpx 0;border-bottom:1rpx solid var(--border);}
.step-item:last-child{border-bottom:none;}
.step-num{width:40rpx;height:40rpx;border-radius:50%;background:var(--accent);color:#fff;font-size:22rpx;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:4rpx;}
.step-text{font-size:28rpx;line-height:1.6;flex:1;}
