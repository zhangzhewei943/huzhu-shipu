.page{display:flex;flex-direction:column;min-height:100vh;background:var(--cream);}
.header{display:flex;justify-content:space-between;align-items:center;padding:20rpx 32rpx;background:var(--cream);}
.brand{display:flex;align-items:center;gap:12rpx;}
.icon{font-size:36rpx;}
.title{font-size:34rpx;font-weight:700;color:var(--fg);}
.capsule{display:flex;align-items:center;gap:8rpx;font-size:24rpx;color:var(--muted);}
.body{flex:1;display:flex;overflow:hidden;}

/* 侧边栏 */
.sidebar{width:160rpx;background:var(--surface);padding:16rpx 0;}
.cat-item{padding:24rpx 20rpx;font-size:26rpx;color:var(--muted);display:flex;align-items:center;gap:8rpx;}
.cat-item.active{background:var(--cream);color:var(--accent);font-weight:600;}
.badge{font-size:20rpx;background:var(--accent);color:#fff;border-radius:20rpx;padding:2rpx 12rpx;margin-left:auto;}
.cat-dot{width:12rpx;height:12rpx;border-radius:50%;}
.cat-dot-meat{background:#E88F8F;}.cat-dot-veg{background:#6FBF6F;}.cat-dot-salad{background:#8FC8E8;}
.cat-dot-soup{background:#B8A8D8;}.cat-dot-rice{background:#E8B44F;}.cat-dot-cake{background:#E88FC8;}.cat-dot-wine{background:#C8A88F;}
.side-clear{display:flex;align-items:center;gap:8rpx;padding:24rpx 20rpx;font-size:24rpx;color:var(--muted);margin-top:8rpx;}
.clear-icon{font-size:24rpx;}
.recipe-card.selected{border-color:var(--accent);background:var(--accent-light);}
.card-name{font-size:30rpx;font-weight:600;display:block;margin-bottom:6rpx;}
.card-time{font-size:24rpx;color:var(--muted);display:block;}
.card-add{padding:10rpx 24rpx;border-radius:24rpx;font-size:24rpx;color:var(--accent);border:2rpx solid var(--accent);white-space:nowrap;}
.card-add.added{background:var(--accent);color:#fff;}

/* 主区域 */
.main{flex:1;padding:16rpx 24rpx;background:var(--cream);}
.search-bar{display:flex;align-items:center;gap:12rpx;padding:20rpx 24rpx;background:var(--surface);border-radius:16rpx;margin-bottom:20rpx;}
.search-icon{font-size:28rpx;flex-shrink:0;}
.search-input{flex:1;font-size:28rpx;color:var(--fg);}
.sec-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx;}
.sec-title{font-size:32rpx;font-weight:600;}.sec-count{font-size:24rpx;color:var(--accent);}

.recipe-card{display:flex;align-items:center;gap:16rpx;padding:20rpx;background:var(--surface);border-radius:16rpx;margin-bottom:16rpx;}
.card-photo{width:90rpx;height:90rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:40rpx;}
.card-info{flex:1;}
.card-name{font-size:30rpx;font-weight:600;display:block;margin-bottom:6rpx;}
.card-time{font-size:24rpx;color:var(--muted);}
.card-add{padding:10rpx 24rpx;border-radius:24rpx;font-size:24rpx;color:var(--accent);border:2rpx solid var(--accent);}
.card-add.added{background:var(--accent);color:#fff;}

/* 右下角悬浮按钮 */
.fab{position:fixed;right:32rpx;bottom:calc(200rpx + env(safe-area-inset-bottom));width:120rpx;height:120rpx;border-radius:50%;background:var(--accent);display:flex;flex-direction:column;align-items:center;justify-content:center;box-shadow:0 8rpx 24rpx rgba(217,133,49,0.4);z-index:99;}
.fab-num{font-size:36rpx;font-weight:700;color:#fff;line-height:1;}
.fab-text{font-size:20rpx;color:rgba(255,255,255,0.9);}
